<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
                   ExtensionBundleId="com.willpsdk.premieresync"
                   ExtensionBundleVersion="1.1.0"
                   ExtensionBundleName="willpsdk Premiere Sync"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.willpsdk.premieresync.panel" Version="1.1.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 2019 (13.0) and newer -->
      <Host Name="PPRO" Version="[13.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.willpsdk.premieresync.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/hostscript.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>willpsdk Premiere Sync</Menu>
          <Geometry>
            <Size>
              <Height>640</Height>
              <Width>440</Width>
            </Size>
            <MinSize>
              <Height>320</Height>
              <Width>320</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
